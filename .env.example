# Server configuration (private - backend only)
PORT=3000
HOST=0.0.0.0

# Database path (SQLite) - private
DATABASE_PATH=./data/claude-manager.db

# Authentication - private (server-only)
MASTER_PASSWORD=your-secure-master-password-here
JWT_SECRET=your-jwt-secret-here

# Public variables (accessible in browser via $env/static/public)
# Use PUBLIC_ prefix for SvelteKit frontend
PUBLIC_API_URL=http://localhost:3000
