{
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@eslint/js": "^9.39.2",
		"@types/bun": "^1.3.4",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.2",
		"eslint-plugin-storybook": "^10.1.10",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"svelte-check": "^4.3.4",
		"svelte-eslint-parser": "^1.4.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.50.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"bunx @biomejs/biome check --write",
			"bunx eslint --fix"
		],
		"*.{json,css,md}": [
			"bunx @biomejs/biome check --write"
		],
		"*.svelte": [
			"bunx @biomejs/biome check --write",
			"bunx eslint --fix"
		]
	},
	"name": "claude-manager",
	"private": true,
	"scripts": {
		"build": "bun run --filter '*' build",
		"check": "bun run --filter '*' check",
		"dev": "concurrently -n backend,frontend -c blue,magenta \"bun run dev:backend\" \"bun run dev:frontend\"",
		"dev:backend": "bun run --filter '@claude-manager/backend' dev",
		"dev:frontend": "bun run --filter '@claude-manager/frontend' dev",
		"lint": "bunx @biomejs/biome check . && bun run lint:eslint && bun run lint:svelte-check",
		"lint:biome": "bunx @biomejs/biome check .",
		"lint:eslint": "bunx eslint --no-warn-ignored 'apps/**/*.{ts,svelte}'",
		"lint:fix": "bunx @biomejs/biome check --write . && bunx eslint --fix 'apps/**/*.{ts,svelte}'",
		"lint:svelte-check": "bunx svelte-check --workspace apps/frontend",
		"pre:commit": "bun run typecheck && bun run lint",
		"prepare": "husky",
		"test": "bun run --filter '*' test",
		"typecheck": "bun run tsc --noEmit"
	},
	"type": "module",
	"workspaces": [
		"apps/*"
	]
}
