{
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@eslint/js": "^9.39.3",
		"@types/bun": "^1.3.9",
		"bun-tasks": "^0.1.2",
		"eslint": "^9.39.3",
		"eslint-plugin-storybook": "^10.2.12",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"svelte-check": "^4.4.3",
		"svelte-eslint-parser": "^1.5.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"bunx @biomejs/biome check --write",
			"bunx eslint --fix"
		],
		"*.{json,css}": [
			"bunx @biomejs/biome check --write"
		],
		"*.svelte": [
			"bunx @biomejs/biome check --write",
			"bunx eslint --fix"
		]
	},
	"name": "claude-manager",
	"private": true,
	"scripts": {
		"build": "bun run --filter '*' build",
		"check": "bun run --filter '*' check",
		"dev": "bun-tasks dev:backend ::: dev:frontend",
		"dev:backend": "bun run --filter '@claude-manager/backend' dev",
		"dev:caddy": "caddy run --config Caddyfile",
		"dev:frontend": "bun run --filter '@claude-manager/frontend' dev",
		"dev:public": "bun-tasks dev:backend ::: dev:frontend ::: dev:caddy",
		"lint": "bunx @biomejs/biome check . && bun run lint:eslint && bun run lint:svelte-check",
		"lint:biome": "bunx @biomejs/biome check .",
		"lint:eslint": "bunx eslint --no-warn-ignored 'apps/**/*.{ts,svelte}'",
		"lint:fix": "bunx @biomejs/biome check --write . && bunx eslint --fix 'apps/**/*.{ts,svelte}'",
		"lint:svelte-check": "bunx svelte-check --workspace apps/frontend",
		"pre:commit": "bun run typecheck && bun run lint",
		"prepare": "husky",
		"test": "bun run --filter '*' test",
		"typecheck": "bun run typecheck:common && bun run typecheck:backend && bun run typecheck:frontend",
		"typecheck:backend": "tsc --noEmit -p apps/backend/tsconfig.json",
		"typecheck:common": "tsc --noEmit -p apps/common/tsconfig.json",
		"typecheck:frontend": "svelte-check --workspace apps/frontend"
	},
	"type": "module",
	"workspaces": [
		"apps/*"
	]
}
