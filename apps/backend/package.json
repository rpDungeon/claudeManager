{
	"dependencies": {
		"@claude-manager/common": "workspace:*",
		"@elysiajs/bearer": "^1.4.2",
		"@elysiajs/cors": "^1.1.1",
		"@elysiajs/jwt": "^1.1.1",
		"@mistralai/mistralai": "^1.11.0",
		"@xterm/addon-serialize": "^0.14.0",
		"@xterm/headless": "^6.0.0",
		"bun-pty": "^0.4.2",
		"chokidar": "^5.0.0",
		"drizzle-orm": "^0.38.3",
		"elysia": "^1.2.9",
		"nanoid": "^5.0.9",
		"simple-git": "^3.30.0",
		"typescript-language-server": "^5.1.3",
		"vscode-langservers-extracted": "^4.10.0",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@elysiajs/eden": "^1.4.6",
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.5.0",
		"bun-types": "latest",
		"drizzle-kit": "^0.30.1",
		"typescript": "^5.9.3"
	},
	"exports": {
		".": "./src/index.ts",
		"./api": "./src/api.ts"
	},
	"module": "src/index.ts",
	"name": "@claude-manager/backend",
	"private": true,
	"scripts": {
		"build": "bun build src/index.ts --outdir=dist --target=bun",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev": "../../scripts/with-clean-env.sh bun run --env-file=../../.env --watch src/index.ts",
		"start": "../../scripts/with-clean-env.sh bun run --env-file=../../.env dist/index.js",
		"test": "../../scripts/with-clean-env.sh bun test --env-file=../../.env --preload ./src/test/setup.ts"
